fn main(args: String[1]) {
    var inputStr = args[0];
    var parsingResult = parse_int(inputStr).expect("Cannot parse \n $inputStr");

    println("fibo($input) = ${fibo(input)}");
}

fn fibo(n: int): int {
    if (n <= 1) {
        return n;
    }

    return fibo(n - 1) + fibo(n - 2);
}

type Mapping = fn(x: int): string


type Tree = Leaf | Node
type Leaf = string
type Node = Tree[]

type StringTree = string | StringTree[] | interface {
    yeet()
}